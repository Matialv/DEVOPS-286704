          "item": [
            {
              "name": "Listar productos",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Cookie", "value": "token={{ADMIN_TOKEN}}" }
                ],
                "url": {
                  "raw": "{{ALB}}/admin/api/products",
                  "host": ["{{ALB}}"],
                  "path": ["admin", "api", "products"]
                }
              }
            },
            {
              "name": "Crear producto",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Cookie", "value": "token={{ADMIN_TOKEN}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Nuevo producto\",\n  \"description\": \"Descripción del producto\",\n  \"price\": 49.99\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{ALB}}/admin/api/products",
                  "host": ["{{ALB}}"],
                  "path": ["admin", "api", "products"]
                }
              }
            },
            {
              "name": "Actualizar producto",
              "request": {
                "method": "PUT",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Cookie", "value": "token={{ADMIN_TOKEN}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Producto actualizado\",\n  \"description\": \"Nueva descripción\",\n  \"price\": 59.99\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{ALB}}/admin/api/products/{{PRODUCT_ID}}",
                  "host": ["{{ALB}}"],
                  "path": ["admin", "api", "products", "{{PRODUCT_ID}}"]
                }
              }
            },
            {
              "name": "Eliminar producto",
              "request": {
                "method": "DELETE",
                "header": [
                  { "key": "Cookie", "value": "token={{ADMIN_TOKEN}}" }
                ],
                "url": {
                  "raw": "{{ALB}}/admin/api/products/{{PRODUCT_ID}}",
                  "host": ["{{ALB}}"],
                  "path": ["admin", "api", "products", "{{PRODUCT_ID}}"]
                }
              }
            }
          ]
        },
